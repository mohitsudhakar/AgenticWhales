# AgenticWhales — example environment.
# Copy to `.env` and fill in your own values. `.env` is gitignored.

# ---------- LLM provider API keys ----------
# You only need the key for the provider you actually use. The default is
# Google (Gemini) — see AGENTICWHALES_DEFAULT_PROVIDER below.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# The other providers are commented out in web/server.py PROVIDERS for now;
# uncomment those entries to bring them back, then fill in the matching key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=     # Qwen
ZHIPU_API_KEY=         # GLM
OPENROUTER_API_KEY=

# ---------- Supabase (auth + per-day usage cap + session/batch storage) ----------
# URL and anon key are public-by-design — the anon key ships in the browser
# bundle. Security comes from Row Level Security (see docs/supabase-schema.sql).
AGENTICWHALES_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
AGENTICWHALES_SUPABASE_ANON_KEY=
AGENTICWHALES_SUPABASE_SERVICE_KEY=

# Service-role key — server-side ONLY. Bypasses RLS, used by web/auth.py to
# upsert session/batch rows on behalf of the runner. NEVER expose this to
# the browser.
AGENTICWHALES_SUPABASE_SERVICE_KEY=

# ---------- Admin (usage dashboard) ----------
# Email of the single operator allowed to see /api/admin/dashboard. Compared
# case-insensitively against the Supabase user's email. Defaults to
# mohit.sudhakar@gmail.com if unset.
AGENTICWHALES_ADMIN_EMAIL=mohit.sudhakar@gmail.com

# ---------- Default provider + models ----------
# Pre-selected on the new-analysis and basket forms. Update these when a new
# model launches (e.g. set DEEP=gemini-4-pro once it's in the catalog at
# tradingagents/llm_clients/model_catalog.py).
AGENTICWHALES_DEFAULT_PROVIDER=google
AGENTICWHALES_DEFAULT_DEEP_MODEL=gemini-3.1-pro-preview
AGENTICWHALES_DEFAULT_QUICK_MODEL=gemini-3-flash-preview

# ---------- Repeat-analysis cache ----------
# When ENABLED, a POST /api/sessions for the same (ticker, analysis_date,
# config) within TTL_MINUTES of a prior successful run returns that
# existing session instead of starting a new one. Saves LLM cost and
# the hit doesn't count toward the daily quota.
AGENTICWHALES_CACHE_ENABLED=true
AGENTICWHALES_CACHE_TTL_MINUTES=30

# ---------- Server bind (optional) ----------
# AGENTICWHALES_WEB_HOST=127.0.0.1
# AGENTICWHALES_WEB_PORT=8765

# ---------- X (Twitter) trade-recs analyzer ----------
# App Bearer Token for the official X API v2, from https://developer.x.com
# (paid Basic tier+ — the v2 user-tweets / recent-search endpoints used by
# the X trade-recs analyzer are not on the free tier). When unset,
# get_x_trade_recs() returns a "not configured" message instead of calling X.
# X_BEARER_TOKEN=PASTE_FROM_X_DEVELOPER_PORTAL
